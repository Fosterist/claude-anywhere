# Copy to .env and fill in real values. Never commit the real .env.

# --- bot ---
TELEGRAM_TOKEN=123456:your-bot-token-from-BotFather
ADMIN_CHAT_ID=your-telegram-chat-id
AGENT_TOKEN=generate-a-long-random-string-shared-between-bot-and-agent
HTTP_ADDR=:8090
DB_PATH=claude-anywhere.db
CONFIG_PATH=projects.json

# --- agent ---
# Use 127.0.0.1, not localhost — on some Windows setups (VPN adapters
# especially) IPv6 loopback (::1, what "localhost" resolves to first) is
# blocked while IPv4 loopback works fine, and the agent will fail to connect.
BOT_URL=http://127.0.0.1:8090
CLAUDE_BIN=claude
